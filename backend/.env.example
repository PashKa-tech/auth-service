DOMAIN=localhost
API_BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENV=development
APP_NAME="Auth Service"
DATABASE_URL=sqlite+aiosqlite:///./dev.db
USE_FAKEREDIS=true
JWT_SECRET_KEY=dev_jwt_secret_key_change_me_in_production
SUPER_ADMIN_API_KEY=super-admin-secret-key-change-me

# Google OAuth
# Redirect URI: http://localhost:8000/api/v1/auth/oauth/google/callback
ENABLE_GOOGLE_OAUTH=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
# Redirect URI: http://localhost:8000/api/v1/auth/oauth/github/callback
ENABLE_GITHUB_OAUTH=true
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Discord OAuth
# Redirect URI: http://localhost:8000/api/v1/auth/oauth/discord/callback
ENABLE_DISCORD_OAUTH=true
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Apple OAuth
# Redirect URI: http://localhost:8000/api/v1/auth/oauth/apple/callback
ENABLE_APPLE_OAUTH=true
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Facebook OAuth
# Redirect URI: http://localhost:8000/api/v1/auth/oauth/facebook/callback
ENABLE_FACEBOOK_OAUTH=true
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Twitter (X) OAuth
# Redirect URI: http://localhost:8000/api/v1/auth/oauth/twitter/callback
ENABLE_TWITTER_OAUTH=true
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Amazon OAuth
# Redirect URI: http://localhost:8000/api/v1/auth/oauth/amazon/callback
ENABLE_AMAZON_OAUTH=true
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=

# SMTP / Email Settings (mocked by default)
USE_MOCK_EMAIL=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@authservice.com

# 2FA Settings
TOTP_ENCRYPTION_KEY=your_base64_encoded_32_byte_key_here
