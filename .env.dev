DOMEN=localhost
ENV=development
APP_NAME="Auth Service"
DATABASE_URL=sqlite+aiosqlite:///./dev.db
USE_FAKEREDIS=true
JWT_SECRET_KEY=dev_jwt_secret_key_change_me_in_production
SUPER_ADMIN_API_KEY=super-admin-secret-key-change-me

# Google OAuth
ENABLE_GOOGLE_OAUTH=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth
ENABLE_GITHUB_OAUTH=true
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Discord OAuth
ENABLE_DISCORD_OAUTH=true
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Apple OAuth
ENABLE_APPLE_OAUTH=true
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# Facebook OAuth
ENABLE_FACEBOOK_OAUTH=true
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# Twitter (X) OAuth
ENABLE_TWITTER_OAUTH=true
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# Amazon OAuth
ENABLE_AMAZON_OAUTH=true
AMAZON_CLIENT_ID=
AMAZON_CLIENT_SECRET=

# SMTP / Email Settings (mocked by default)
USE_MOCK_EMAIL=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@authservice.com

# 2FA Settings
TOTP_ENCRYPTION_KEY=ZJJGPpPg_Z2Dlsy6kzBGhaU3C99YPs5rS-vElHb_aIc=

