ENV=development
APP_NAME="Auth Service"
DATABASE_URL=sqlite+aiosqlite:///./dev.db
USE_FAKEREDIS=true
JWT_SECRET_KEY=dev_jwt_secret_key_change_me_in_production
SUPER_ADMIN_API_KEY=super-admin-secret-key-change-me

# Google OAuth (optional in dev)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# GitHub OAuth (optional in dev)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/github/callback

# SMTP / Email Settings (mocked by default)
USE_MOCK_EMAIL=true
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@authservice.com

# 2FA Settings
TOTP_ENCRYPTION_KEY=ZJJGPpPg_Z2Dlsy6kzBGhaU3C99YPs5rS-vElHb_aIc=

